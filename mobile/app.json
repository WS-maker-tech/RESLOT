{
  "expo": {
    "name": "Reslot",
    "slug": "reslot",
    "scheme": "reslot",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-video",
      "expo-web-browser",
      "react-native-edge-to-edge"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "web": {
      "favicon": "./favicon.png",
      "bundler": "metro",
      "name": "Reslot",
      "shortName": "Reslot",
      "description": "Din genväg till fullbokade restauranger."
    },
    "icon": "./assets/logo/icon-1024.png",
    "splash": {
      "backgroundColor": "#FAFAF8"
    }
  }
}