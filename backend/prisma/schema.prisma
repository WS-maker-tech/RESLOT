datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Restaurant {
  id                 String   @id @default(cuid())
  name               String
  address            String
  cuisine            String
  neighborhood       String
  rating             Float
  reviewCount        Int
  priceLevel         Int
  image              String
  description        String
  tags               String
  timesBookedOnReslot Int     @default(0)
  demandMultiplier    Float   @default(1.0)  // Dynamic pricing: multiplier based on restaurant demand
  seatType           String
  instagram          String?
  website            String?
  vibeTags           String
  goodForTags        String
  foodTags           String
  latitude           Float?
  longitude          Float?
  isExclusive        Boolean  @default(false)
  city               String   @default("Stockholm")
  googlePlaceId      String?  @unique  // Link to Google Places API
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  reservations       Reservation[]
  restaurantAlerts   RestaurantAlert[]
  watches            Watch[]
  savedByUsers       SavedRestaurant[]
}

model Reservation {
  id                       String   @id @default(cuid())
  restaurantId             String
  restaurant               Restaurant @relation(fields: [restaurantId], references: [id])
  submitterPhone           String
  submitterFirstName       String
  submitterLastName        String
  reservationDate          DateTime
  reservationTime          String
  partySize                Int
  seatType                 String
  nameOnReservation        String
  status                   String   @default("active") // active, claimed, grace_period, completed, cancelled, no_show, resold
  claimerPhone             String?
  claimedAt                DateTime?
  graceDeadline            DateTime?
  creditStatus             String   @default("none") // none, pending, awarded, reverted
  serviceFee               Float?
  stripePaymentIntentId    String?
  captureStatus            String   @default("none") // none, pending, captured, failed
  cancelFee                Float?
  prepaidAmount            Float?
  verificationLink         String?
  extraInfo                String?
  cancellationWindowHours  Int?
  creditCost               Int      @default(2)     // Dynamic pricing: credit cost for claiming (default 2)
  noShowFeeCharged         Boolean  @default(false)
  noShowFeePaymentIntentId String?
  resoldFromId             String?  // ID of the original reservation if this was created via resale
  version                  Int      @default(0) // Optimistic locking
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  noShowReports            NoShowReport[]
  reports                  ReservationReport[]
  feedback                 ReservationFeedback?

  @@index([status])
  @@index([submitterPhone])
  @@index([claimerPhone])
  @@index([restaurantId])
  @@index([reservationDate])
  @@index([status, claimedAt])
}

model UserProfile {
  id                String   @id @default(cuid())
  phone             String   @unique
  firstName         String
  lastName          String
  email             String
  avatar            String?
  credits           Int      @default(0)
  selectedCity      String   @default("Stockholm")
  dateOfBirth       String?
  emailVerified     Boolean  @default(false)
  phoneVerified     Boolean  @default(true)
  referralCode      String?  @unique
  referralUsed      String?
  stripeCustomerId  String?  @unique
  pushToken         String?
  trustScore        Float    @default(5.0)   // Aggregated trust score (1-5)
  totalFeedbacks    Int      @default(0)     // Total number of feedbacks received
  isDeleted         Boolean  @default(false)
  deletedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Watch {
  id            String     @id @default(cuid())
  userPhone     String
  restaurantId  String?
  restaurant    Restaurant? @relation(fields: [restaurantId], references: [id])
  date          String?
  partySize     Int?
  notes         String?
  filterOptions String?    // JSON: { timeRange?: [string,string], weekdays?: number[], partySize?: number }
  createdAt     DateTime   @default(now())

  @@index([userPhone])
}

model RestaurantAlert {
  id           String     @id @default(cuid())
  userPhone    String
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  enabled      Boolean    @default(true)
  createdAt    DateTime   @default(now())
}

model ActivityAlert {
  id           String   @id @default(cuid())
  userPhone    String
  type         String
  title        String
  message      String
  read         Boolean  @default(false)
  restaurantId String?
  createdAt    DateTime @default(now())

  @@index([userPhone])
  @@index([userPhone, read])
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone, used])
}

model Session {
  id        String   @id @default(cuid())
  phone     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model NoShowReport {
  id            String   @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  reporterPhone String
  reason        String
  evidenceUrl   String?
  status        String   @default("pending") // pending, confirmed, rejected
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ProcessedEvent {
  id        String   @id // Stripe event ID
  type      String   // event type (e.g. payment_intent.succeeded)
  createdAt DateTime @default(now())
}

model SavedRestaurant {
  id           String     @id @default(cuid())
  userPhone    String
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([userPhone, restaurantId])
  @@index([userPhone])
}

model EmailVerification {
  id        String   @id @default(cuid())
  phone     String
  email     String
  code      String
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone, used])
  @@index([email, used])
}

// --- Google Places cache ---
model RestaurantCache {
  placeId       String   @id            // Google Place ID
  name          String
  address       String
  city          String
  neighborhood  String?
  latitude      Float?
  longitude     Float?
  rating        Float?
  reviewCount   Int?
  priceLevel    Int?
  cuisine       String?
  imageUrl      String?
  website       String?
  instagram     String?
  phone         String?
  openingHours  String?  // JSON string
  tags          String?  // JSON string
  rawGoogleData String?  // Full Google Places response (JSON)
  cachedAt      DateTime @default(now())
  expiresAt     DateTime

  @@index([city])
  @@index([name])
  @@index([expiresAt])
}

// --- Reservation reports ---
model ReservationReport {
  id            String   @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  reporterPhone String
  reason        String   // booking_not_found, wrong_details, restaurant_denied, fraud
  details       String?
  status        String   @default("pending") // pending, reviewed, resolved
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([reservationId])
  @@index([reporterPhone])
}

// --- Reservation feedback (post-booking) ---
model ReservationFeedback {
  id            String   @id @default(cuid())
  reservationId String   @unique          // One feedback per reservation
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  userPhone     String                    // The claimer giving feedback
  worked        Boolean                   // Did the booking work? (Ja/Nej)
  comment       String?                   // Optional free text
  createdAt     DateTime @default(now())

  @@index([userPhone])
  @@index([reservationId])
}
