generator client {
  provider      = "prisma-client-js"
  // native: local dev; rhel targets: Vercel Lambda (Amazon Linux 2 / AL2023)
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Restaurant {
  id                  String            @id @default(cuid())
  name                String
  address             String
  cuisine             String
  neighborhood        String
  rating              Float
  reviewCount         Int               @default(0)
  priceLevel          Int
  image               String
  description         String
  tags                Json              @default("[]")
  timesBookedOnReslot Int               @default(0)
  demandMultiplier    Float             @default(1.0)
  seatType            String
  instagram           String?
  website             String?
  vibeTags            Json              @default("[]")
  goodForTags         Json              @default("[]")
  foodTags            Json              @default("[]")
  latitude            Float?
  longitude           Float?
  isExclusive         Boolean           @default(false)
  city                String            @default("Stockholm")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  reservations        Reservation[]
  restaurantAlerts    RestaurantAlert[]
  savedByUsers        SavedRestaurant[]
  watches             Watch[]

  @@index([city, cuisine, neighborhood])
}

model Reservation {
  id                       String               @id @default(cuid())
  restaurantId             String
  submitterPhone           String
  submitterFirstName       String
  submitterLastName        String
  reservationDate          DateTime
  reservationTime          String
  partySize                Int
  seatType                 String
  nameOnReservation        String
  status                   ReservationStatus    @default(active)
  claimerPhone             String?
  claimedAt                DateTime?
  graceDeadline            DateTime?
  creditStatus             String               @default("none")
  serviceFee               Float?
  stripePaymentIntentId    String?
  captureStatus            String               @default("none")
  cancelFee                Float?
  prepaidAmount            Float?
  verificationLink         String?
  extraInfo                String?
  cancellationWindowHours  Int?
  creditCost               Int                  @default(2)
  noShowFeeCharged         Boolean              @default(false)
  noShowFeePaymentIntentId String?
  resoldFromId             String?
  reminderSent             Boolean              @default(false)
  version                  Int                  @default(0)
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  noShowReports            NoShowReport[]
  restaurant               Restaurant           @relation(fields: [restaurantId], references: [id])
  feedback                 ReservationFeedback?
  reports                  ReservationReport[]

  @@index([status])
  @@index([submitterPhone])
  @@index([claimerPhone])
  @@index([restaurantId])
  @@index([reservationDate])
  @@index([status, claimedAt])
  @@index([restaurantId, reservationDate, status])
}

model UserProfile {
  id               String    @id @default(cuid())
  phone            String    @unique
  firstName        String
  lastName         String
  email            String
  avatar           String?
  credits          Int       @default(0)
  selectedCity     String    @default("Stockholm")
  dateOfBirth      String?
  emailVerified    Boolean   @default(false)
  phoneVerified    Boolean   @default(true)
  referralCode     String?   @unique
  referralUsed     String?
  stripeCustomerId String?   @unique
  pushToken        String?
  trustScore       Float     @default(5.0)
  totalFeedbacks   Int       @default(0)
  isDeleted        Boolean   @default(false)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Watch {
  id            String      @id @default(cuid())
  userPhone     String
  restaurantId  String?
  date          String?
  partySize     Int?
  notes         String?
  filterOptions Json?
  createdAt     DateTime    @default(now())
  restaurant    Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([userPhone])
  @@index([restaurantId])
}

model RestaurantAlert {
  id           String     @id @default(cuid())
  userPhone    String
  restaurantId String
  enabled      Boolean    @default(true)
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([userPhone])
}

model ActivityAlert {
  id           String   @id @default(cuid())
  userPhone    String
  type         String
  title        String
  message      String
  read         Boolean  @default(false)
  restaurantId String?
  createdAt    DateTime @default(now())

  @@index([userPhone])
  @@index([userPhone, read])
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone, used])
}

model Session {
  id        String   @id @default(cuid())
  phone     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}

model NoShowReport {
  id            String      @id @default(cuid())
  reservationId String
  reporterPhone String
  reason        String
  evidenceUrl   String?
  status        String      @default("pending")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
}

model ProcessedEvent {
  id        String   @id
  type      String
  createdAt DateTime @default(now())
}

model SavedRestaurant {
  id           String     @id @default(cuid())
  userPhone    String
  restaurantId String
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userPhone, restaurantId])
  @@index([userPhone])
}

model EmailVerification {
  id        String   @id @default(cuid())
  phone     String
  email     String
  code      String
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone, used])
  @@index([email, used])
}

model RestaurantCache {
  placeId       String   @id
  name          String
  address       String
  city          String
  neighborhood  String?
  latitude      Float?
  longitude     Float?
  rating        Float?
  reviewCount   Int?
  priceLevel    Int?
  cuisine       String?
  imageUrl      String?
  website       String?
  instagram     String?
  phone         String?
  openingHours  String?
  tags          String?
  rawGoogleData String?
  cachedAt      DateTime @default(now())
  expiresAt     DateTime

  @@index([city])
  @@index([name])
  @@index([expiresAt])
}

model ReservationReport {
  id            String      @id @default(cuid())
  reservationId String
  reporterPhone String
  reason        String
  details       String?
  status        String      @default("pending")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([reporterPhone])
}

model ReservationFeedback {
  id            String      @id @default(cuid())
  reservationId String      @unique
  userPhone     String
  worked        Boolean
  comment       String?
  createdAt     DateTime    @default(now())
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([userPhone])
  @@index([reservationId])
}

enum ReservationStatus {
  active
  claimed
  grace_period
  completed
  cancelled
  no_show
  resold
  payment_failed
}

enum SeatType {
  indoor
  outdoor
  bar
  private_room
  terrace
  any
}
